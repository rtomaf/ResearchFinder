# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-...

# SMTP Settings (required for email delivery)
# Gmail: use an App Password (https://myaccount.google.com/apppasswords)
# Outlook: smtp-mail.outlook.com, port 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Email Settings
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=miriam@miriamllantada.com,ricardo@miriamllantada.com

# Model (optional, defaults to claude-sonnet-4-6-20250514)
# MODEL=claude-sonnet-4-6-20250514
