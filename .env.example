# =============================================================================
# ResearchFinder Configuration
# =============================================================================

# Provider: "anthropic" (Claude) or "openai" (ChatGPT)
PROVIDER=anthropic

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6-20250514
# Other options: claude-opus-4-6-20250514

# --- OpenAI (ChatGPT) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1
# Other options: gpt-4o, gpt-4.1-mini, or whatever model you prefer

# =============================================================================
# SMTP Settings (required for email delivery)
# =============================================================================
# Gmail: use an App Password (https://myaccount.google.com/apppasswords)
# Outlook: smtp-mail.outlook.com, port 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Email Settings
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=miriam@miriamllantada.com,ricardo@miriamllantada.com
